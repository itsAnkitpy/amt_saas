# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Database
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/amt_saas?schema=public"

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_your_key"
CLERK_SECRET_KEY="sk_test_your_key"
CLERK_WEBHOOK_SECRET="whsec_your_webhook_secret"

# Storage
# Leave empty in local development to use the local storage/ directory.
BLOB_READ_WRITE_TOKEN=""

# Optional seed values
# Used by prisma/seed.ts when creating a seeded superadmin.
SUPERADMIN_CLERK_ID=""
SUPERADMIN_EMAIL=""
