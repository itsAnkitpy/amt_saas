// AMT SaaS - Prisma Schema
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// MULTI-TENANCY
// ============================================

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique // e.g., "acme-corp" for acme-corp.amt.com
  plan      Plan     @default(FREE)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users                   User[]
  assets                  Asset[]
  assetCategories         AssetCategory[]
  departments             Department[]
  notifications           Notification[]
  notificationPreferences NotificationPreference[]

  @@map("tenants")
}

enum Plan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

// ============================================
// USERS & AUTH
// ============================================

model User {
  id           String   @id @default(cuid())
  email        String
  firstName    String
  lastName     String?
  role         Role     @default(USER)
  isSuperAdmin Boolean  @default(false) // NEW: Quick check for admin access
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Tenant relation (optional for superadmin)
  tenantId String? // CHANGED: Nullable for superadmin users
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Department relation (optional)
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  // Assets assigned to user
  assets           Asset[]
  assetAssignments AssetAssignment[]

  // Notification preferences (FK + cascade; prefs are config, not audit)
  notificationPreferences NotificationPreference[]

  // Email unique per tenant (null tenantId = superadmin, unique email)
  @@unique([email, tenantId])
  @@index([tenantId])
  @@map("users")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  USER
}

// ============================================
// ORGANIZATION
// ============================================

model Department {
  id        String   @id @default(cuid())
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Tenant relation
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Relations
  users User[]

  @@unique([name, tenantId])
  @@index([tenantId])
  @@map("departments")
}

// ============================================
// ASSETS
// ============================================

// Asset Category with custom field schema
model AssetCategory {
  id                              String                   @id @default(cuid())
  name                            String
  description                     String?
  icon                            String? // Lucide icon name (e.g., "laptop", "monitor")
  defaultMaintenanceIntervalValue Int?
  defaultMaintenanceIntervalUnit  MaintenanceIntervalUnit?
  defaultMaintenanceInstructions  String?

  // Custom field schema - JSON array defining fields for assets in this category
  // Example: [{"key": "processor", "label": "Processor", "type": "text", "required": true}]
  fieldSchema Json @default("[]")

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Tenant relation
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Assets in this category
  assets Asset[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("asset_categories")
}

// Asset with custom fields support
model Asset {
  id String @id @default(cuid())

  // Core fields (always present)
  name         String
  serialNumber String?
  assetTag     String? // Internal tag like "IT-0001"

  // Category relation
  categoryId String
  category   AssetCategory @relation(fields: [categoryId], references: [id])

  // Custom field values - JSON object matching category's fieldSchema
  // Example: {"processor": "Intel i7", "ram": "16GB", "storage": "512GB SSD"}
  customFields Json @default("{}")

  // Status
  status    AssetStatus    @default(AVAILABLE)
  condition AssetCondition @default(GOOD)

  // Location
  location String?

  // Financial
  purchasePrice Decimal?  @db.Decimal(10, 2)
  purchaseDate  DateTime?
  warrantyEnd   DateTime?

  // Notes
  notes String?

  // Metadata
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime? // Set when asset is soft-deleted (RETIRED)

  // Tenant relation
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Current assignee (denormalized for quick access)
  assignedToId String?
  assignedTo   User?   @relation(fields: [assignedToId], references: [id])

  // Assignment history
  assignments AssetAssignment[]

  // Asset images
  images AssetImage[]

  // Maintenance
  maintenanceSchedule AssetMaintenanceSchedule?
  maintenanceJobs     MaintenanceJob[]

  // Activity log
  activities AssetActivity[]

  @@unique([tenantId, serialNumber])
  @@unique([tenantId, assetTag])
  @@index([tenantId])
  @@index([categoryId])
  @@index([status])
  @@map("assets")
}

// Asset assignment history
model AssetAssignment {
  id String @id @default(cuid())

  // Asset being assigned
  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  // User being assigned to
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Assignment period
  assignedAt DateTime  @default(now())
  returnedAt DateTime? // Null means currently assigned

  // Notes
  notes String?

  @@index([assetId])
  @@index([userId])
  @@map("asset_assignments")
}

// Asset images with private storage
model AssetImage {
  id String @id @default(cuid())

  // Asset relation
  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  // File metadata
  fileName     String // Original filename from upload
  filePath     String // Storage path: "tenant-id/assets/asset-id/original-xxx.jpg"
  thumbPath    String? // Thumbnail path (optional)
  mimeType     String // "image/jpeg", "image/png", etc.
  size         Int // File size in bytes
  blobUrl      String? // Full Vercel Blob URL (null for local storage)
  thumbBlobUrl String? // Thumbnail Blob URL (null for local storage)

  // Display
  isPrimary Boolean @default(false)
  sortOrder Int     @default(0)

  // Metadata
  createdAt DateTime @default(now())

  @@index([assetId])
  @@map("asset_images")
}

enum AssetStatus {
  AVAILABLE
  ASSIGNED
  MAINTENANCE
  RETIRED
}

enum AssetCondition {
  EXCELLENT
  GOOD
  FAIR
  POOR
}

enum MaintenanceIntervalUnit {
  DAYS
  WEEKS
  MONTHS
  YEARS
}

model AssetMaintenanceSchedule {
  id            String                  @id @default(cuid())
  assetId       String                  @unique
  asset         Asset                   @relation(fields: [assetId], references: [id], onDelete: Cascade)
  intervalValue Int
  intervalUnit  MaintenanceIntervalUnit
  instructions  String?
  isActive      Boolean                 @default(true)
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  jobs MaintenanceJob[]

  @@index([isActive])
  @@map("asset_maintenance_schedules")
}

enum MaintenanceJobStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model MaintenanceJob {
  id              String                   @id @default(cuid())
  assetId         String
  asset           Asset                    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  scheduleId      String
  schedule        AssetMaintenanceSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  status          MaintenanceJobStatus     @default(OPEN)
  dueAt           DateTime
  startedAt       DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  notes           String?
  cost            Decimal?                 @db.Decimal(10, 2)
  completedById   String?
  completedByName String?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  @@index([assetId, status])
  @@index([scheduleId, status])
  @@index([status, dueAt])
  @@map("maintenance_jobs")
}

// ============================================
// AUDIT TRAIL
// ============================================

// Asset activity log for audit trail
model AssetActivity {
  id String @id @default(cuid())

  // What happened
  action  AssetAction
  details Json? // Action-specific context + performedBy

  // To which asset
  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  // By whom (historical reference, NO foreign key to survive user deletion)
  userId String

  // When
  createdAt DateTime @default(now())

  // Tenant for isolation
  tenantId String

  @@index([assetId])
  @@index([tenantId, createdAt])
  @@index([tenantId, action])
  @@map("asset_activities")
}

enum AssetAction {
  CREATED
  UPDATED
  ASSIGNED
  UNASSIGNED
  STATUS_CHANGED
  DELETED
  RESTORED
  IMAGE_ADDED
  IMAGE_REMOVED
  MAINTENANCE_SCHEDULED
  MAINTENANCE_UPDATED
  MAINTENANCE_DISABLED
  MAINTENANCE_STARTED
  MAINTENANCE_COMPLETED
  MAINTENANCE_CANCELLED
}

// ============================================
// NOTIFICATIONS (Module 10)
// ============================================

enum NotificationType {
  MAINTENANCE_OVERDUE
  MAINTENANCE_DUE_SOON
  WARRANTY_EXPIRING
  ASSET_ASSIGNED_TO_YOU
}

enum NotificationSourceType {
  MAINTENANCE_JOB
  ASSET
  ASSET_ASSIGNMENT
}

model Notification {
  id String @id @default(cuid())

  // Routing
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // No FK on userId (mirrors AssetActivity) — preserves delivery history after user delete
  userId   String

  // Classification
  type       NotificationType
  sourceType NotificationSourceType
  sourceId   String

  // Fire-once dedupe key — shape per-type:
  //   MAINTENANCE_OVERDUE    -> "job:<jobId>"
  //   MAINTENANCE_DUE_SOON   -> "job:<jobId>"
  //   WARRANTY_EXPIRING      -> "asset:<assetId>:<warrantyEnd-ISODate>"
  //   ASSET_ASSIGNED_TO_YOU  -> "assignment:<assignmentId>"
  dedupeKey String

  // Pre-rendered display
  title   String
  body    String
  payload Json?

  // Channel-visibility flags (set per recipient prefs at write time)
  inAppVisible  Boolean @default(true)
  emailEligible Boolean @default(true)

  // State
  readAt      DateTime?
  dismissedAt DateTime?
  emailSentAt DateTime?

  createdAt DateTime @default(now())

  @@unique([tenantId, userId, type, dedupeKey])
  @@index([userId, tenantId, dismissedAt, readAt, createdAt])
  @@index([tenantId, emailEligible, emailSentAt, readAt, dismissedAt])
  @@map("notifications")
}

model NotificationPreference {
  id String @id @default(cuid())

  // FK + cascade — prefs are config, not audit
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  type  NotificationType
  inApp Boolean          @default(true)
  email Boolean          @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, userId, type])
  @@index([tenantId, userId])
  @@map("notification_preferences")
}
